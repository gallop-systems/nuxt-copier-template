{% if ci_runner == 'self-hosted' %}{% set runner = '[self-hosted, gallop-ci]' %}{% else %}{% set runner = 'ubuntu-latest' %}{% endif %}name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

# Cancel superseded PR runs: pushing again to a branch aborts its in-flight run,
# so we never pay for CI on commits a newer push already replaced. Left on for
# `pull_request` only â€” every commit that lands on `main` still runs to
# completion (don't cancel history / deploy signals).
concurrency:
  group: {% raw %}ci-${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: {% raw %}${{ github.event_name == 'pull_request' }}{% endraw %}

permissions:
  contents: write
  pull-requests: write
  checks: write

jobs:
  # Size the backend test matrix to the suite: ~40 test files per shard, capped.
  # Per-shard cost is ~60s fixed overhead + ~2s/test-file and the `build` job
  # floors the gate at a few minutes, so sharding finer than ~50 files/shard buys
  # no gate improvement. A fresh project with a handful of tests gets a single
  # shard (1/1) and pays no fan-out overhead; the count grows on its own.
  shard-plan:
    runs-on: {{ runner }}
    outputs:
      shards: {% raw %}${{ steps.plan.outputs.shards }}{% endraw %}
    steps:
      - uses: actions/checkout@v4
      - id: plan
        run: |
          count=$(find server -name '*.test.ts' | wc -l | tr -d ' ')
          per=40  # target test files per shard
          max=6   # don't fan out wider than this regardless of suite size
          total=$(( (count + per - 1) / per ))
          [ "$total" -lt 1 ] && total=1
          [ "$total" -gt "$max" ] && total=$max
          shards=$(seq 1 "$total" | jq -R . | jq -cs .)
          echo "shards=$shards" >> "$GITHUB_OUTPUT"
          echo "Planned $total shard(s) for $count backend test files"

  test:
    name: test (shard {% raw %}${{ matrix.shard }}/${{ strategy.job-total }}{% endraw %})
    runs-on: {{ runner }}
    needs: shard-plan
    strategy:
      fail-fast: false
      matrix:
        shard: {% raw %}${{ fromJSON(needs.shard-plan.outputs.shards) }}{% endraw %}
    services:
      postgres:
        image: postgres:18
        env:
          POSTGRES_DB: {{ database_name }}-test
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - name: Run backend tests (shard {% raw %}${{ matrix.shard }}/${{ strategy.job-total }}{% endraw %})
        # No --coverage on the critical path: shards run fast and gate the merge.
        # Each matrix leg gets its own isolated postgres service, so shards never
        # contend on the database â€” the transaction-rollback fixture keeps tests
        # within a shard isolated too. To read coverage, run `yarn test:run
        # --coverage` locally; it's intentionally not a CI job (see git history).
        run: yarn test:run --shard={% raw %}${{ matrix.shard }}/${{ strategy.job-total }}{% endraw %}
        env:
          TEST_POSTGRESQL_CONNECTION_STRING: postgres://postgres:postgres@localhost:5432/{{ database_name }}-test
          NODE_OPTIONS: --experimental-strip-types

  # Everything that doesn't touch the database, behind a SINGLE `yarn install`.
  # Was three separate jobs (static / typecheck / test-frontend); each repaid a
  # cold checkout + node + install (~1min) and billed its own rounded-up minute,
  # so folding them removes redundant install minutes. They run sequentially
  # here â€” `build` (the other heavy job) stays separate so the two 6GB-heap steps
  # (typecheck + build) don't serialize and stretch the gate.
  checks:
    runs-on: {{ runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      # oxlint + oxfmt are Rust-fast (sub-second) and run first so a lint/format
      # failure surfaces before the slower typecheck.
      - run: yarn lint
      - run: yarn fmt:check
      - run: yarn typecheck
        env:
          # tsc is the memory-hungry step; give Node a larger heap so the
          # typecheck doesn't OOM on the runner as the project grows.
          NODE_OPTIONS: --experimental-strip-types --max-old-space-size=6144
      - run: yarn test:frontend:run
        env:
          NODE_OPTIONS: --experimental-strip-types

  build:
    runs-on: {{ runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - run: yarn build
        env:
          NODE_OPTIONS: --experimental-strip-types --max-old-space-size=6144
      - name: Boot the production build
        # typecheck and tests never exercise the real `.output` server, so they
        # miss failures that only surface there â€” e.g. a dependency that
        # resolves in dev but not under the built server's native ESM loader.
        # This boots `.output` and fails if it crashes or never starts listening.
        run: |
          node .output/server/index.mjs > server.log 2>&1 &
          SERVER_PID=$!
          for i in $(seq 1 30); do
            if grep -q "Listening on" server.log; then
              echo "âś“ production server booted"
              kill "$SERVER_PID" 2>/dev/null || true
              exit 0
            fi
            if ! kill -0 "$SERVER_PID" 2>/dev/null; then
              echo "âś— production server crashed on boot:"
              cat server.log
              exit 1
            fi
            sleep 1
          done
          echo "âś— production server did not boot within 30s:"
          cat server.log
          kill "$SERVER_PID" 2>/dev/null || true
          exit 1

  # Stable aggregate gate. The sharded `test` job's check names include the shard
  # total (e.g. "test (shard 1/4)"), which changes as the suite grows â€” so they
  # can't be used as required status checks. Require THIS single context in
  # branch protection instead; it passes only if every gating job did.
  # `needs.test.result` rolls the whole matrix into one result, so this stays
  # correct regardless of shard count.
  ci-success:
    name: ci-success
    if: always()
    needs: [shard-plan, test, checks, build]
    runs-on: {{ runner }}
    steps:
      - name: Verify all required jobs succeeded
        run: |
          results="{% raw %}${{ join(needs.*.result, ' ') }}{% endraw %}"
          echo "gating job results: $results"
          for r in $results; do
            [ "$r" = "success" ] || { echo "âś— a required job failed or was skipped"; exit 1; }
          done
          echo "âś“ all required jobs succeeded"
