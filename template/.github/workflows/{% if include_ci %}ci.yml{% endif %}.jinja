name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

# Cancel superseded PR runs: pushing again to a branch aborts its in-flight run,
# so we never pay for CI on commits a newer push already replaced. Left on for
# `pull_request` only — every commit that lands on `main` still runs to
# completion (don't cancel history / deploy signals).
concurrency:
  group: {% raw %}ci-${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: {% raw %}${{ github.event_name == 'pull_request' }}{% endraw %}

permissions:
  contents: write
  pull-requests: write
  checks: write

jobs:
  # Backend tests. No sharding: the `build` job is the gate's long pole (a few
  # minutes), and the test suite finishes well under that, so splitting it across
  # shards wouldn't move when CI goes green — it would only multiply the billed
  # per-shard install/checkout minutes. Vitest parallelizes across worker threads
  # within this one job. If the suite ever grows large enough to rival the build
  # time, reintroduce a shard matrix then.
  test:
    runs-on: ubuntu-latest
    # Run the job in a container so the postgres service is reachable by its
    # label hostname (`postgres`) on a private per-job network — no host-port
    # mapping needed.
    container: node:24
    services:
      postgres:
        image: postgres:18
        env:
          POSTGRES_DB: {{ database_name }}-test
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v4
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - name: Run backend tests
        # Vitest parallelizes across worker threads within this one job. No
        # --coverage on the critical path; run `yarn test:run --coverage`
        # locally (intentionally not a CI job — see git history).
        run: yarn test:run
        env:
          # `postgres` = the service label, resolvable on the per-job network.
          # sslmode=disable: the service speaks no SSL and isn't on localhost, so
          # opt out explicitly (see server/utils/db.ts).
          NUXT_DATABASE_URL_TEST: postgres://postgres:postgres@postgres:5432/{{ database_name }}-test?sslmode=disable
          NODE_OPTIONS: --experimental-strip-types

  # Everything that doesn't touch the database, behind a SINGLE `yarn install`.
  # Was three separate jobs (static / typecheck / test-frontend); each repaid a
  # cold checkout + node + install (~1min) and billed its own rounded-up minute,
  # so folding them removes redundant install minutes. They run sequentially
  # here — `build` (the other heavy job) stays separate so the two 6GB-heap steps
  # (typecheck + build) don't serialize and stretch the gate.
  checks:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '24'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      # oxlint + oxfmt are Rust-fast (sub-second) and run first so a lint/format
      # failure surfaces before the slower typecheck.
      - run: yarn lint
      - run: yarn fmt:check
      - run: yarn typecheck
        env:
          # tsc is the memory-hungry step; give Node a larger heap so the
          # typecheck doesn't OOM on the runner as the project grows.
          NODE_OPTIONS: --experimental-strip-types --max-old-space-size=6144
      - run: yarn test:frontend:run
        env:
          NODE_OPTIONS: --experimental-strip-types

  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '24'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - run: yarn build
        env:
          NODE_OPTIONS: --experimental-strip-types --max-old-space-size=6144
      - name: Boot and render-check the production build
        # typecheck and tests never exercise the real `.output` server, so they
        # miss failures that only surface there — e.g. a dependency that resolves
        # in dev but not under the built server's native ESM loader. Crucially
        # those often 500 at *render* time, not at boot: the server listens fine,
        # then errors when a page is actually requested. So: boot, wait for it to
        # listen, then render the home route and fail on a 5xx. Boot-only misses
        # render failures entirely.
        run: |
          node .output/server/index.mjs > server.log 2>&1 &
          SERVER_PID=$!
          # 1) wait for it to listen (fail fast if it crashes on boot)
          for i in $(seq 1 30); do
            grep -q "Listening on" server.log && break
            if ! kill -0 "$SERVER_PID" 2>/dev/null; then
              echo "✗ production server crashed on boot:"; cat server.log; exit 1
            fi
            sleep 1
          done
          if ! grep -q "Listening on" server.log; then
            echo "✗ production server did not boot within 30s:"; cat server.log
            kill "$SERVER_PID" 2>/dev/null || true; exit 1
          fi
          echo "✓ booted; render-checking the home route"
          # 2) render a real route — a 5xx means the server served an error page
          # instead of rendering (the gap boot-only misses). 2xx/3xx/4xx are fine.
          code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 20 http://localhost:3000/ || echo 000)
          echo "  GET / -> $code"
          kill "$SERVER_PID" 2>/dev/null || true
          if [ "$code" = "000" ] || [ "$code" -ge 500 ]; then
            echo "✗ / returned 5xx (or no response) — SSR render failure:"
            tail -50 server.log; exit 1
          fi
          echo "✓ home route renders (no 5xx)"

  # Stable aggregate gate to require in branch protection; passes only if every
  # gating job did. Require THIS single context (not the individual jobs) so the
  # required-checks list never has to change as jobs are added or renamed.
  ci-success:
    name: ci-success
    if: always()
    needs: [test, checks, build]
    runs-on: ubuntu-latest
    steps:
      - name: Verify all required jobs succeeded
        run: |
          results="{% raw %}${{ join(needs.*.result, ' ') }}{% endraw %}"
          echo "gating job results: $results"
          for r in $results; do
            [ "$r" = "success" ] || { echo "✗ a required job failed or was skipped"; exit 1; }
          done
          echo "✓ all required jobs succeeded"
