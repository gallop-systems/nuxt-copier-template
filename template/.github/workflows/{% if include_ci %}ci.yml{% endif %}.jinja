name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: write
  pull-requests: write
  checks: write

jobs:
  test:
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:15
        env:
          POSTGRES_DB: {{ database_name }}-test
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - name: Run backend tests with coverage
        run: yarn test --coverage
        env:
          TEST_POSTGRESQL_CONNECTION_STRING: postgres://postgres:postgres@localhost:5432/{{ database_name }}-test
          NODE_OPTIONS: --experimental-strip-types
      - name: Run frontend tests
        run: yarn test:frontend:run
        env:
          NODE_OPTIONS: --experimental-strip-types
      - name: Upload coverage artifacts
        uses: actions/upload-artifact@v4
        with:
          name: coverage
          path: coverage/
          retention-days: 7

  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - run: yarn typecheck
      - run: yarn lint
      - run: yarn fmt:check

  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - run: corepack enable
      - name: Get yarn cache directory
        id: yarn-cache
        run: echo "dir=$(yarn config get cacheFolder)" >> $GITHUB_OUTPUT
      - uses: actions/cache@v4
        with:
          path: {% raw %}${{ steps.yarn-cache.outputs.dir }}{% endraw %}
          key: {% raw %}yarn-${{ runner.os }}-${{ hashFiles('yarn.lock') }}{% endraw %}
          restore-keys: {% raw %}yarn-${{ runner.os }}-{% endraw %}
      - run: yarn install --immutable
      - run: yarn build
      - name: Boot the production build
        # typecheck and tests never exercise the real `.output` server, so they
        # miss failures that only surface there — e.g. a dependency that
        # resolves in dev but not under the built server's native ESM loader.
        # This boots `.output` and fails if it crashes or never starts listening.
        run: |
          node .output/server/index.mjs > server.log 2>&1 &
          SERVER_PID=$!
          for i in $(seq 1 30); do
            if grep -q "Listening on" server.log; then
              echo "✓ production server booted"
              kill "$SERVER_PID" 2>/dev/null || true
              exit 0
            fi
            if ! kill -0 "$SERVER_PID" 2>/dev/null; then
              echo "✗ production server crashed on boot:"
              cat server.log
              exit 1
            fi
            sleep 1
          done
          echo "✗ production server did not boot within 30s:"
          cat server.log
          kill "$SERVER_PID" 2>/dev/null || true
          exit 1

  coverage:
    runs-on: ubuntu-latest
    needs: test
    if: {% raw %}github.event_name == 'pull_request'{% endraw %}
    steps:
      - uses: actions/checkout@v4
      - name: Download coverage artifacts
        uses: actions/download-artifact@v4
        with:
          name: coverage
          path: coverage/
      - name: Coverage Report on PR
        uses: davelosert/vitest-coverage-report-action@v2
        with:
          json-summary-path: ./coverage/coverage-summary.json
          json-final-path: ./coverage/coverage-final.json
          vite-config-path: ./vitest.config.ts
      - name: Coverage Summary
        run: |
          COVERAGE=$(node -e "const c = require('./coverage/coverage-summary.json'); console.log(c.total.lines.pct)")
          echo "## Coverage Report" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Metric | Coverage |" >> $GITHUB_STEP_SUMMARY
          echo "|--------|----------|" >> $GITHUB_STEP_SUMMARY
          node -e "
            const c = require('./coverage/coverage-summary.json').total;
            console.log('| Lines | ' + c.lines.pct + '% |');
            console.log('| Statements | ' + c.statements.pct + '% |');
            console.log('| Functions | ' + c.functions.pct + '% |');
            console.log('| Branches | ' + c.branches.pct + '% |');
          " >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "**Total: ${COVERAGE}% line coverage**" >> $GITHUB_STEP_SUMMARY
