name: Check Template Updates

on:
  schedule:
    - cron: '0 9 * * *' # Daily at 9am UTC
  workflow_dispatch:

permissions:
  contents: write
  pull-requests: write

jobs:
  check-updates:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Get current template version
        id: current
        run: |
          VERSION=$(grep '_commit:' .copier-answers.yml | awk '{print $2}')
          echo "version=$VERSION" >> $GITHUB_OUTPUT

      - name: Get latest template version
        id: latest
        run: |
          LATEST=$(git ls-remote --tags --refs --sort=-v:refname https://github.com/gallop-systems/nuxt-copier-template.git 'v*' | head -1 | sed 's/.*refs\/tags\///')
          echo "version=$LATEST" >> $GITHUB_OUTPUT

      - name: Check if update needed
        id: check
        run: |
          if [ "${{ '{{' }} steps.current.outputs.version {{ '}}' }}" != "${{ '{{' }} steps.latest.outputs.version {{ '}}' }}" ]; then
            echo "needs_update=true" >> $GITHUB_OUTPUT
          else
            echo "needs_update=false" >> $GITHUB_OUTPUT
          fi

      - name: Create update branch and PR
        if: steps.check.outputs.needs_update == 'true'
        env:
          GH_TOKEN: ${{ '{{' }} secrets.GITHUB_TOKEN {{ '}}' }}
        run: |
          BRANCH="chore/template-update"

          # Check if PR already exists for this branch
          if gh pr list --head "$BRANCH" --state open --json number --jq length | grep -q "^[1-9]"; then
            echo "PR already exists, skipping"
            exit 0
          fi

          # Delete remote branch if it exists (merged/closed PR or failed run)
          if git ls-remote --exit-code --heads origin "$BRANCH" > /dev/null 2>&1; then
            echo "Deleting existing remote branch"
            git push origin --delete "$BRANCH"
          fi

          # Configure git
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

          # Create branch with empty commit
          git checkout -b "$BRANCH"
          git commit --allow-empty -m "chore: template update available"
          git push -u origin "$BRANCH"

          # Create PR
          gh pr create \
            --title "🔄 Template update available" \
            --body "## Template Update Available

          The upstream template has new changes available.

          **Current version:** \`${{ '{{' }} steps.current.outputs.version {{ '}}' }}\`
          **Latest version:** \`${{ '{{' }} steps.latest.outputs.version {{ '}}' }}\`

          ### What's new?

          [View release notes](https://github.com/gallop-systems/nuxt-copier-template/releases/tag/${{ '{{' }} steps.latest.outputs.version {{ '}}' }}) | [Compare changes](https://github.com/gallop-systems/nuxt-copier-template/compare/${{ '{{' }} steps.current.outputs.version {{ '}}' }}...${{ '{{' }} steps.latest.outputs.version {{ '}}' }})

          ---

          ### Instructions for Claude

          To apply this template update:

          1. Checkout this branch and pull latest
          2. Run: \`uvx copier update --trust --defaults\`
             - Use \`uvx copier\`, not \`copier\` directly (copier is not installed globally)
             - Always include \`--defaults\` flag (required for non-interactive terminal)
          3. Review and resolve any merge conflicts
          4. Commit changes with message: \`chore: update to template vX.Y.Z\`
          5. Update this PR title to: \`chore: update to template vX.Y.Z\` (get version from \`.copier-answers.yml\` \`_commit\` field after update, or from git tags on the template repo)
          6. Push and merge when CI passes

          ---
          *This PR was automatically created by the template update checker.*"
