<template>
{%- raw %}
  <header class="border-b border-surface-200 bg-surface-0 dark:border-surface-800 dark:bg-surface-900">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3">
        <h1 class="text-lg font-semibold text-surface-900 dark:text-surface-0">{{ projectName }}</h1>
      </div>
      <div class="flex items-center gap-4">
        <VoltAvatar v-if="user" :label="initials" shape="circle" />
        <VoltButton v-if="user" label="Log out" severity="secondary" size="small" @click="logout" />
      </div>
    </div>
  </header>
{% endraw -%}
</template>

<script setup lang="ts">
const projectName = "{{ project_name }}";
const { user, clear: logout } = useUserSession();
const { getInitials } = useFormatters();

const initials = computed(() => {
  if (!user.value) return "";
  const name =
    `${(user.value as any).first_name ?? ""} ${(user.value as any).last_name ?? ""}`.trim();
  return getInitials(name);
});
</script>
