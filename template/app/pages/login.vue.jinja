<template>
{%- raw %}
  <div class="flex min-h-screen items-center justify-center bg-canvas">
    <div class="w-full max-w-sm space-y-6 px-4">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-fg">{{ projectName }}</h1>
        <p class="mt-2 text-sm text-fg-muted">Sign in to continue</p>
      </div>
{%- endraw %}
{%- if include_google_oauth %}
{%- raw %}
      <VoltButton
        label="Sign in with Google"
        icon="pi pi-google"
        class="w-full"
        @click="signInWithGoogle"
      />
{%- endraw %}
{%- endif %}
{%- raw %}
      <VoltSecondaryButton
        v-if="previewMode"
        label="Sign in as preview user"
        icon="pi pi-eye"
        class="w-full"
        @click="signInAsPreviewUser"
      />
    </div>
  </div>
{%- endraw %}
</template>

<script setup lang="ts">
definePageMeta({
  layout: false,
});

const projectName = "{{ project_name }}";

// Only true inside a preview box (see nuxt.config public.previewMode). Surfaces
// the dev-mode preview-login button; the endpoint is gated on the same flag.
const previewMode = useRuntimeConfig().public.previewMode;

function signInAsPreviewUser() {
  navigateTo("/api/auth/preview-login", { external: true });
}
{%- if include_google_oauth %}

function signInWithGoogle() {
  navigateTo("/api/auth/google", { external: true });
}
{%- endif %}
</script>
