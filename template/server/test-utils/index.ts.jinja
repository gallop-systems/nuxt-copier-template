import { vi, test as base, expect } from "vitest";
import { createEvent } from "h3";
import { IncomingMessage, ServerResponse } from "http";
import { Socket } from "net";
import { db } from "../utils/db";
import type { Transaction } from "kysely";
import type { DB } from "../db/db";

let currentTrx: Transaction<DB> | null = null;

/**
 * Stub useDatabase() to return the current test transaction.
 */
export function setupHandlerMocks() {
  vi.stubGlobal("useDatabase", () => {
    if (!currentTrx) throw new Error("No active test transaction");
    return currentTrx;
  });

  vi.stubGlobal("defineEventHandler", (fn: Function) => fn);

  vi.stubGlobal("createError", (opts: { statusCode: number; message: string }) => {
    const err = new Error(opts.message) as any;
    err.statusCode = opts.statusCode;
    return err;
  });

  vi.stubGlobal("getQuery", (event: any) => event.__query || {});
  vi.stubGlobal("readBody", (event: any) => event.__body || {});
  vi.stubGlobal("getRouterParam", (event: any, name: string) => event.__params?.[name]);

  vi.stubGlobal("getUserSession", async () => ({
    user: { id: 1, email: "test@example.com", first_name: "Test", last_name: "User" },
  }));
}

/**
 * Create a mock H3 event for GET requests.
 */
export function mockGet(query: Record<string, string> = {}, params: Record<string, string> = {}) {
  const req = new IncomingMessage(new Socket());
  req.method = "GET";
  req.url = "/";
  const res = new ServerResponse(req);
  const event = createEvent(req, res);
  (event as any).__query = query;
  (event as any).__params = params;
  return event;
}

