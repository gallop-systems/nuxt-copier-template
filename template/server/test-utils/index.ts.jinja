/**
 * Assert that a handler throws an HTTP error with the given status code.
 */
export async function expectHttpError(fn: () => Promise<any>, statusCode: number) {
  try {
    await fn();
    throw new Error(`Expected HTTP ${statusCode} error but none was thrown`);
  } catch (err: any) {
    expect(err.statusCode).toBe(statusCode);
    return err;
  }
}

/**
 * Factory helpers for creating test records.
 */
function createFactories(trx: Transaction<DB>) {
  return {
    async user(data: Partial<{
      email: string;
      first_name: string;
      last_name: string;
    }> = {}) {
      const num = Math.floor(Math.random() * 10000);
      return trx
        .insertInto("users")
        .values({
          email: data.email ?? `test${num}@example.com`,
          first_name: data.first_name ?? "Test",
          last_name: data.last_name ?? "User",
        })
        .returningAll()
        .executeTakeFirstOrThrow();
    },
  };
}

type Factories = ReturnType<typeof createFactories>;

interface TestContext {
  factories: Factories;
}

/**
 * Custom test fixture that wraps each test in a transaction
 * that is rolled back after the test completes.
 */
export const test = base.extend<TestContext>({
  factories: async ({}, use) => {
    const trx = await db.transaction().execute(async (trx) => {
      currentTrx = trx;
      const factories = createFactories(trx);
      await use(factories);
      // Force rollback by throwing after test completes
      throw new Error("ROLLBACK");
    }).catch((err) => {
      if (err.message !== "ROLLBACK") throw err;
    });
  },
});

export { describe, expect } from "vitest";
