{
  "name": "{{ project_name }}",
  "type": "module",
  "private": true,
  "description": "{{ project_description }}",
  "scripts": {
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "test:frontend": "VITEST_ENV=nuxt vitest",
    "test:frontend:run": "VITEST_ENV=nuxt vitest run",
    "db:migrate": "kysely migrate:latest",
    "db:migrate:down": "kysely migrate:down",
    "db:migrate:make": "kysely migrate:make",
    "db:seed": "kysely seed:run",
    "db:seed:make": "kysely seed:make",
    "db:codegen": "kysely-codegen --url $NUXT_DATABASE_URL --out-file server/db/db.d.ts --dialect postgres --date-parser string",
    "typecheck": "nuxt typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@tailwindcss/vite": "^4.1.18",
    "date-fns": "^4.1.0",
    "kysely": "^0.29.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.27",
    "pg": "^8.16.3",
    "primevue": "^4.5.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "@vueuse/core": "^14.0.0",
    "vue": "^3.5.26",
    "vue-router": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@gallopsystems/agent-skills": "^1.16.0",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/simple-icons": "^1.2.88",
    "@nuxt/icon": "^2.2.5",
    "@nuxt/test-utils": "^4.0.0",
    "@types/pg": "^8.16.0",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^14.0.0",
    "happy-dom": "^20.1.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.21.0",
    {% if include_git_hooks %}"lefthook": "latest",{% endif %}
    "oxlint": "latest",
    "oxfmt": "latest",
    "@vitest/coverage-v8": "^4.0.17",
    "vitest": "^4.0.17",
    "typescript": "^6.0.0",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "yarn@4.12.0"
}
