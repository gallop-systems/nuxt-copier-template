NUXT_DATABASE_URL=postgresql://localhost:5432/{{ database_name }}
# Connection string for the test database (used by the vitest suite). Defaults to
# postgresql://localhost/{{ database_name }}-test when unset.
# NUXT_DATABASE_URL_TEST=postgresql://localhost:5432/{{ database_name }}-test
NUXT_SESSION_PASSWORD=
{% if auth_provider == 'google' %}
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
{% elif auth_provider == 'microsoft' %}
NUXT_OAUTH_MICROSOFT_CLIENT_ID=
NUXT_OAUTH_MICROSOFT_TENANT=
NUXT_OAUTH_MICROSOFT_CLIENT_SECRET=
{% endif %}
# Set only inside a preview/sandbox box (leave unset locally and in prod). When
# set, /login shows a "Sign in as preview user" button that logs in as the seeded
# anchor user (server/db/seeds) without OAuth. Double-gated: the endpoint
# also requires import.meta.dev, so it can never exist in a production build.
# NUXT_PREVIEW_MODE=true
